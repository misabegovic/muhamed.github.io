---
layout: null
permalink: /brain.xml
---

<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.name }} — Peek into my brain</title>
  <link href="{{ site.url }}/brain.xml" rel="self"/>
  <link href="{{ site.url }}/"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}/brain.xml</id>
  <author>
    <name>{{ site.author }}</name>
  </author>

  {% assign sorted = site.stream | sort: 'date' | reverse | limit: 20 %}
  {% for entry in sorted %}
  <entry>
    <title>{{ entry.title }}</title>
    <link href="{% if entry.url_external %}{{ entry.url_external }}{% else %}{{ site.url }}{{ entry.url }}{% endif %}"/>
    <updated>{{ entry.date | date_to_xmlschema }}</updated>
    <id>{{ site.url }}{{ entry.url }}</id>
    <content type="html">
      {% if entry.quote %}&lt;blockquote&gt;“{{ entry.quote }}”&lt;/blockquote&gt;{% endif %}
      {{ entry.content | xml_escape }}
      {% if entry.url_external %}&lt;p&gt;&lt;a href="{{ entry.url_external }}"&gt;Original source&lt;/a&gt;&lt;/p&gt;{% endif %}
    </content>
  </entry>
  {% endfor %}
</feed>
