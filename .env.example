# pi-brain environment variables
#
# Copy this file to .env and fill in the tokens you need.
# Never commit .env to git.

# GitHub connector — read-only public repo access works without a token,
# but higher rate limits and private repos need a classic or fine-grained token.
GITHUB_TOKEN=""

# Notion connector — read-only integration token.
NOTION_TOKEN=""

# Slack connector — read-only user token.
SLACK_TOKEN=""

# Local-first mode — suspend PR/CI rituals for single-operator use.
LOCAL_FIRST="false"
